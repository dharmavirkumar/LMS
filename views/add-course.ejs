<style>
  /* Tailwind CDN ke saath @apply kaam nahi karta */
  .input {
    width: 100%;
    padding: 12px 14px;
    border: 1px solid #d1d5db;
    border-radius: 10px;
    outline: none;
    transition: all 0.3s ease;
  }

  .input:focus {
    border-color: #9333ea;
    box-shadow: 0 0 0 3px rgba(147, 51, 234, 0.2);
  }

  .section-title {
    font-weight: 700;
    margin-bottom: 12px;
    font-size: 1.1rem;
    color: #1f2937;
  }

  .btn-secondary {
    background: #f3f4f6;
    padding: 10px 16px;
    border-radius: 10px;
    transition: 0.3s;
    font-weight: 600;
    cursor: pointer;
  }

  .btn-secondary:hover {
    background: #e5e7eb;
  }
</style>

<form
  action="/admin/add-course"
  method="POST"
  enctype="multipart/form-data"
  class="space-y-6 max-w-4xl mx-auto bg-white p-8 rounded-2xl shadow-2xl"
>
  <h2 class="text-3xl font-bold text-purple-600 text-center">
    📚 Add New Course
  </h2>

  <!-- BASIC INFO -->
  <div class="grid gap-4">
    <input
      type="text"
      name="title"
      placeholder="Course Title"
      required
      class="input"
    />

    <textarea
      name="description"
      placeholder="Course Description"
      rows="4"
      class="input"
      required
    ></textarea>

    <input
      type="number"
      name="price"
      placeholder="Course Price"
      min="0"
      required
      class="input"
    />

    <select name="category" required class="input">
      <option value="">Select Category</option>
      <option>Web Development</option>
      <option>Data Science</option>
      <option>App Development</option>
      <option>AI / ML</option>
    </select>

    <input
      type="file"
      name="thumbnail"
      accept="image/*"
      onchange="previewImage(event)"
      required
      class="input"
    />

    <img
      id="thumbPreview"
      class="w-40 hidden rounded-xl shadow-lg border"
      alt="Thumbnail Preview"
    />
  </div>

  <!-- MODULES -->
  <div>
    <h3 class="section-title">📦 Modules</h3>

    <div id="modules-container"></div>

    <button
      type="button"
      onclick="addModule()"
      class="btn-secondary mt-3"
    >
      + Add Module
    </button>
  </div>

  <!-- CONTENT -->
  <div>
    <h3 class="section-title">📘 Content</h3>
    <div id="content-container" class="space-y-2"></div>

    <button
      type="button"
      onclick="addInput('content-container','content[]')"
      class="btn-secondary"
    >
      + Add Content
    </button>
  </div>

  <!-- OBJECTIVES -->
  <div>
    <h3 class="section-title">🎯 Objectives</h3>
    <div id="objectives-container" class="space-y-2"></div>

    <button
      type="button"
      onclick="addInput('objectives-container','objectives[]')"
      class="btn-secondary"
    >
      + Add Objective
    </button>
  </div>

  <!-- FEATURES -->
  <div>
    <h3 class="section-title">🚀 Features</h3>
    <div id="features-container" class="space-y-2"></div>

    <button
      type="button"
      onclick="addInput('features-container','features[]')"
      class="btn-secondary"
    >
      + Add Feature
    </button>
  </div>

  <!-- CAREER -->
  <div>
    <h3 class="section-title">💼 Career Benefits</h3>
    <div id="career-container"></div>

    <button
      type="button"
      onclick="addCareer()"
      class="btn-secondary"
    >
      + Add Benefit
    </button>
  </div>

  <!-- CERTIFICATIONS -->
  <div>
    <h3 class="section-title">🏆 Certifications</h3>
    <div id="cert-container" class="space-y-2"></div>

    <button
      type="button"
      onclick="addInput('cert-container','certifications[]')"
      class="btn-secondary"
    >
      + Add Certification
    </button>
  </div>

  <button
    id="submitBtn"
    type="submit"
    class="w-full bg-purple-600 text-white py-4 rounded-xl font-bold text-lg hover:bg-purple-700 transition"
  >
    Upload Course
  </button>
</form>

<script>

  // ================= MODULE =================
  function addModule() {

    const moduleId = "module_" + Date.now();

    const moduleDiv = document.createElement("div");

    moduleDiv.className =
      "module-box border-2 border-purple-100 p-5 rounded-2xl mb-5 bg-purple-50";

    moduleDiv.setAttribute("data-module-id", moduleId);

    moduleDiv.innerHTML = `
      <input type="hidden" name="moduleId[]" value="${moduleId}" />

      <input
        name="moduleTitle[]"
        placeholder="Module Title"
        required
        class="input mb-3"
      />

      <div class="lessons space-y-3"></div>

      <div class="flex gap-2 mt-3">
        <button
          type="button"
          class="btn-secondary"
          onclick="addLesson(this)"
        >
          + Add Lesson
        </button>

        <button
          type="button"
          onclick="this.closest('.module-box').remove()"
          class="bg-red-500 text-white px-4 py-2 rounded-lg"
        >
          Delete Module
        </button>
      </div>
    `;

    document
      .getElementById("modules-container")
      .appendChild(moduleDiv);
  }

  // ================= LESSON =================
  function addLesson(button) {

    const moduleBox = button.closest(".module-box");
    const moduleId = moduleBox.getAttribute("data-module-id");

    const lessonDiv = document.createElement("div");

    lessonDiv.className =
      "grid md:grid-cols-4 gap-3 items-center";

    lessonDiv.innerHTML = `
      <input
        type="hidden"
        name="lessonModuleId[]"
        value="${moduleId}"
      />

      <input
        name="lessonTitle[]"
        placeholder="Lesson Title"
        required
        class="input"
      />

      <input
        type="file"
        name="videos"
        accept="video/*"
        required
        class="input"
      />

      <button
        type="button"
        class="bg-red-500 text-white px-4 py-3 rounded-lg"
        onclick="this.parentElement.remove()"
      >
        Remove
      </button>
    `;

    moduleBox
      .querySelector(".lessons")
      .appendChild(lessonDiv);
  }

  // ================= GENERIC INPUT =================
  function addInput(containerId, name) {

    const wrapper = document.createElement("div");

    wrapper.className = "flex gap-2 items-center";

    wrapper.innerHTML = `
      <input
        name="${name}"
        required
        class="input"
      />

      <button
        type="button"
        class="bg-red-500 text-white px-4 rounded-lg"
        onclick="this.parentElement.remove()"
      >
        ✕
      </button>
    `;

    document
      .getElementById(containerId)
      .appendChild(wrapper);
  }

  // ================= CAREER =================
  function addCareer() {

    const div = document.createElement("div");

    div.className =
      "grid md:grid-cols-3 gap-3 mb-3 items-center";

    div.innerHTML = `
      <input
        name="careerTitle[]"
        placeholder="Career Title"
        required
        class="input"
      />

      <input
        name="careerDesc[]"
        placeholder="Career Description"
        required
        class="input"
      />

      <button
        type="button"
        class="bg-red-500 text-white px-4 py-3 rounded-lg"
        onclick="this.parentElement.remove()"
      >
        Remove
      </button>
    `;

    document
      .getElementById("career-container")
      .appendChild(div);
  }

  // ================= THUMB PREVIEW =================
  function previewImage(event) {

    const file = event.target.files[0];

    if (!file) return;

    const img = document.getElementById("thumbPreview");

    img.src = URL.createObjectURL(file);

    img.classList.remove("hidden");
  }

  // ================= SUBMIT =================
  document.querySelector("form").addEventListener("submit", function () {

    const btn = document.getElementById("submitBtn");

    btn.disabled = true;

    btn.innerHTML = "⏳ Uploading Course...";
  });

</script>