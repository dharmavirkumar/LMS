<!-- ================= OUR CREDIBILITY ================= -->
<!-- ================= OUR CREDIBILITY ================= -->
<section class="relative overflow-hidden bg-gradient-to-br from-black via-blue-950 to-black text-white py-24 px-6">

  <div class="relative max-w-7xl mx-auto text-center">

    <!-- Badge -->
    <span class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-white/10 border border-white/20 text-cyan-300 font-medium mb-8">
      🚀 Building Trust Through Real Learning
    </span>

    <!-- Heading -->
    <h1 class="text-5xl md:text-7xl font-extrabold leading-tight mb-8">
      Our
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 via-blue-400 to-purple-500">
        Credibility
      </span>
    </h1>

    <!-- Description -->
    <p class="text-xl text-blue-100 max-w-4xl mx-auto leading-relaxed mb-16">
      At Gyansify, we focus on practical learning, real-world experience, 
      and transparent processes. Our goal is to help students build 
      industry-ready skills through hands-on training and guided projects.
    </p>

    <!-- TRUST STATS (REALISTIC) -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">

      <div class="bg-white/10 border border-white/20 rounded-3xl p-8">
        <h3 class="text-4xl font-black text-cyan-400">Growing</h3>
        <p class="text-blue-100 mt-2">Learning Community</p>
      </div>

      <div class="bg-white/10 border border-white/20 rounded-3xl p-8">
        <h3 class="text-4xl font-black text-purple-400">
          <%= courses?.length || 0 %>+
        </h3>
        <p class="text-blue-100 mt-2">Programs & Projects</p>
      </div>

      <div class="bg-white/10 border border-white/20 rounded-3xl p-8">
        <h3 class="text-4xl font-black text-green-400">100%</h3>
        <p class="text-blue-100 mt-2">Practical Learning Focus</p>
      </div>

      <div class="bg-white/10 border border-white/20 rounded-3xl p-8">
        <h3 class="text-4xl font-black text-yellow-400">Verified</h3>
        <p class="text-blue-100 mt-2">Certification System</p>
      </div>

    </div>
  </div>
</section>

<!-- ================= STUDENT PROJECTS ================= -->
<section class="bg-gradient-to-b from-slate-50 to-white py-24 px-6">
  <div class="max-w-7xl mx-auto">

    <div class="text-center mb-20">
      <span class="inline-block px-6 py-2 rounded-full bg-blue-100 text-blue-700 font-semibold mb-6">
        Student Showcase
      </span>

      <h2 class="text-5xl md:text-6xl font-extrabold text-slate-900 mb-6">
        Featured Student Projects
      </h2>

      <p class="text-xl text-slate-600 max-w-3xl mx-auto">
        Real projects built by our students during their learning journey.
      </p>
    </div>

    <% if (courses && courses.length > 0) { %>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-10">

        <% courses.forEach(course => { %>
          <div class="group bg-white rounded-3xl shadow-lg hover:shadow-2xl transition-all duration-500 overflow-hidden border border-slate-100 hover:-translate-y-3">

            <!-- Thumbnail -->
            <div class="relative overflow-hidden">
              <img
                src="<%= course.thumbnail || '/default.jpg' %>"
                alt="<%= course.title %>"
                onerror="this.src='/default.png'"
                class="w-full h-64 object-cover group-hover:scale-110 transition duration-700"
              >

              <div class="absolute top-4 right-4 bg-green-500 text-white px-4 py-2 rounded-full text-sm font-bold shadow-lg">
                Live Project
              </div>
            </div>

            <!-- Content -->
            <div class="p-8">

              <!-- Student -->
              <div class="flex items-center gap-4 mb-6">
                <div class="w-14 h-14 rounded-full bg-gradient-to-r from-blue-600 to-purple-600 flex items-center justify-center text-white text-2xl shadow-lg">
                  👨‍🎓
                </div>

                <div>
                  <h4 class="font-bold text-slate-900 text-lg">
                    <%= course.instructorName || "Student Developer" %>
                  </h4>
                  <p class="text-slate-500 text-sm">
                    Full Stack Developer
                  </p>
                </div>
              </div>

              <!-- Title -->
              <h3 class="text-2xl font-bold text-slate-900 mb-4 line-clamp-2">
                <%= course.title %>
              </h3>

              <p class="text-slate-600 mb-8 line-clamp-3">
                <%= course.description || "A real-world project created by our talented student." %>
              </p>

              <!-- Buttons -->
              <div class="flex gap-4">
                <a href="/course/<%= course._id %>"
                   class="flex-1 text-center bg-gradient-to-r from-blue-600 to-indigo-600 text-white py-3 rounded-xl font-semibold hover:shadow-lg transition">
                  View Project
                </a>

                <button class="px-5 py-3 border border-slate-200 rounded-xl hover:bg-slate-50 transition">
                  ❤️
                </button>
              </div>

              <!-- Mentor -->
              <div class="mt-8 pt-6 border-t border-slate-100 flex items-center justify-between">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 rounded-full bg-purple-100 flex items-center justify-center text-purple-700 font-bold">
                    M
                  </div>

                  <div>
                    <p class="font-semibold text-slate-800">Mentored By</p>
                    <p class="text-sm text-slate-500">Lead Instructor</p>
                  </div>
                </div>

                <span class="text-green-600 font-semibold">
                  Verified ✓
                </span>
              </div>
            </div>
          </div>
        <% }) %>

      </div>
    <% } else { %>

      <!-- Empty State -->
      <div class="max-w-3xl mx-auto">
        <div class="bg-white rounded-3xl shadow-xl border border-slate-100 p-16 text-center">
          <div class="text-8xl mb-8">🚀</div>

          <h3 class="text-4xl font-bold text-slate-900 mb-4">
            Projects Coming Soon
          </h3>

          <p class="text-xl text-slate-600 mb-10">
            Amazing student projects will appear here very soon.
          </p>

          <a href="/courses"
             class="inline-flex items-center gap-3 px-8 py-4 bg-gradient-to-r from-blue-600 to-indigo-600 text-white rounded-2xl font-semibold hover:shadow-xl transition">
            Explore Courses
            <span>→</span>
          </a>
        </div>
      </div>

    <% } %>
  </div>
</section>


