<script src="https://cdn.tailwindcss.com"></script>

<style>
  @media print {
    #downloadBtn {
      display: none !important;
    }

    body {
      background: white !important;
      margin: 0;
      padding: 0;
    }

    .certificate {
      box-shadow: none !important;
      border: 8px solid #1e3a8a !important;
      page-break-inside: avoid;
    }
  }
</style>

<body class="bg-slate-100 py-10 px-4">

  <div class="max-w-5xl mx-auto">

    <div class="certificate bg-white border-8 border-blue-900 shadow-2xl rounded-2xl p-12 relative overflow-hidden">

      <!-- Watermark -->
      <div class="absolute inset-0 flex items-center justify-center opacity-5 pointer-events-none">
        <h1 class="text-[160px] font-black text-slate-900 tracking-widest">
          GYANSIFY
        </h1>
      </div>

      <div class="relative z-10">

        <!-- Logo -->
        <div class="text-center mb-8">
          <img src="/logo.png" alt="Gyansify" class="w-28  mx-auto mb-19 right-30">
          
          <h1 class="text-5xl font-extrabold text-blue-900 tracking-wide">
            CERTIFICATE
          </h1>

          <p class="text-lg text-gray-500 mt-2 tracking-[0.3em] uppercase">
            Of Training
          </p>

          <div class="w-32 h-1 bg-blue-700 mx-auto mt-5 rounded-full"></div>
        </div>

        <!-- Recipient -->
        <div class="text-center mt-10">
          <p class="text-gray-600 text-lg mb-4">
            This Certificate is Proudly Presented To
          </p>

          <h2 class="text-5xl font-bold text-slate-900 border-b-2 border-blue-700 inline-block px-10 pb-3">
            <%= user.name %>
          </h2>
        </div>

        <!-- Description -->
        <div class="text-center max-w-4xl mx-auto mt-12">
          <p class="text-xl text-gray-700 leading-relaxed">
            For successfully completing the professional training program in
          </p>

          <h3 class="text-4xl font-bold text-blue-800 mt-6 mb-6">
            <%= course.title %>
          </h3>

          <p class="text-lg text-gray-600 leading-relaxed">
            Your dedication, commitment, and outstanding performance
            throughout the training program are highly appreciated.
          </p>
        </div>

        <!-- Footer -->
        <div class="grid grid-cols-3 gap-10 mt-20 items-end">

          <!-- Date -->
          <div class="text-center">
            <p class="text-sm text-gray-500 mb-2">Issued On</p>
            <p class="font-bold text-slate-800">
              <%= new Date(certificate.issuedAt).toLocaleDateString() %>
            </p>
            <div class="border-t-2 border-gray-400 mt-4"></div>
          </div>

          <!-- Certificate ID -->
          <div class="text-center">
            <p class="text-sm text-gray-500 mb-2">Certificate ID</p>
            <p class="font-bold text-slate-800 text-sm">
              <%= certificate.certificateId %>
            </p>
            <div class="border-t-2 border-gray-400 mt-4"></div>
          </div>

          <!-- Signature -->
          <div class="text-center">
            <img src="/sig.png" alt="Signature" class="h-20 w-20 mx-auto mb-2">
            <div class="border-t-2 border-gray-400"></div>
            <p class="text-sm font-semibold text-slate-700 mt-2">
              Authorized Signature
            </p>
          </div>

        </div>

      </div>
    </div>

    <!-- Download Button -->
    <div class="text-center mt-8">
      <button
        id="downloadBtn"
        onclick="window.print()"
        class="bg-blue-900 hover:bg-blue-800 text-white px-10 py-4 rounded-xl font-bold shadow-xl transition duration-300"
      >
        Download Certificate
      </button>
    </div>

  </div>

</body>