<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/tailwindcss/2.2.19/tailwind.min.css"/>

<%- include("partial/nav") %>

<section class="min-h-screen bg-gradient-to-br from-slate-950 via-gray-900 to-slate-900 text-white py-20 px-4 sm:px-6">
  <div class="max-w-3xl mx-auto">

    <div class="bg-white/5 backdrop-blur-2xl border border-white/10 rounded-3xl shadow-2xl overflow-hidden">

      <!-- Header -->
      <div class="bg-gradient-to-r from-blue-600 via-purple-600 to-pink-600 p-8 text-center">
        <h1 class="text-4xl font-extrabold mb-3">
          🚀 Submit Your Project
        </h1>
        <p class="text-blue-100 text-lg">
          Upload your project for expert evaluation
        </p>
      </div>

      <div class="p-8 md:p-10">

        <!-- Task Not Found -->
        <% if (!task) { %>
          <div class="bg-red-500/10 border border-red-500/30 rounded-2xl p-8 text-center">
            <div class="text-6xl mb-4">❌</div>
            <h2 class="text-2xl font-bold text-red-400 mb-2">
              Task Not Found
            </h2>
            <p class="text-red-300">
              The requested task does not exist or was removed.
            </p>
          </div>

        <% } else if (alreadySubmitted) { %>

          <!-- Already Submitted -->
          <div class="bg-green-500/10 border border-green-500/30 rounded-2xl p-8 text-center">
            <div class="text-6xl mb-4">✅</div>
            <h2 class="text-3xl font-bold text-green-400 mb-3">
              Already Submitted
            </h2>
            <p class="text-green-200 mb-8">
              You have already submitted this project successfully.
            </p>

            <a href="/internship"
               class="inline-flex items-center gap-2 bg-gradient-to-r from-blue-600 to-purple-600 px-8 py-4 rounded-2xl font-bold hover:scale-105 transition-all duration-300 shadow-xl">
              ← Back to Dashboard
            </a>
          </div>

        <% } else { %>

          <!-- Task Details -->
          <div class="bg-white/5 border border-white/10 rounded-2xl p-6 mb-8">
            <p class="text-sm uppercase tracking-wider text-gray-400 mb-2">
              Task Information
            </p>

            <h2 class="text-2xl font-bold mb-3 text-white">
              <%= task.title || "Untitled Task" %>
            </h2>

            <p class="text-gray-300 leading-relaxed">
              <%= task.description || "No description available." %>
            </p>
          </div>

          <!-- Form -->
          <form
            id="submitForm"
            action="/submit-task"
            method="POST"
            enctype="multipart/form-data"
            class="space-y-8"
          >
            <input
              type="hidden"
              name="taskId"
              value="<%= task._id || '' %>"
            >

            <!-- Project Link -->
            <div>
              <label class="block mb-3 text-lg font-semibold text-gray-200">
                🔗 Project Link
              </label>

              <input
                id="linkInput"
                type="url"
                name="link"
                placeholder="https://github.com/username/project"
                class="w-full px-5 py-4 bg-white/5 border border-white/10 rounded-2xl focus:outline-none focus:ring-4 focus:ring-blue-500/30 focus:border-blue-500 transition-all"
              >
            </div>

            <!-- File Upload -->
            <div>
              <label class="block mb-3 text-lg font-semibold text-gray-200">
                📂 Upload Project File
              </label>

              <input
                id="fileInput"
                type="file"
                name="file"
                accept=".zip,.pdf,.png,.jpg,.jpeg,.doc,.docx"
                class="w-full px-5 py-4 bg-white/5 border border-white/10 rounded-2xl file:mr-4 file:py-2 file:px-4 file:border-0 file:rounded-xl file:bg-blue-600 file:text-white hover:file:bg-blue-700"
              >

              <p class="text-sm text-gray-400 mt-2">
                Supported: ZIP, PDF, DOC, Images
              </p>
            </div>

            <!-- Error Message -->
            <div
              id="errorMsg"
              class="hidden bg-red-500/10 border border-red-500/30 text-red-400 px-5 py-4 rounded-2xl"
            >
              ❌ Please provide either a project link or upload a file.
            </div>

            <!-- Loading -->
            <div
              id="loadingMsg"
              class="hidden bg-blue-500/10 border border-blue-500/30 text-blue-400 px-5 py-4 rounded-2xl"
            >
              ⏳ Uploading your project...
            </div>

            <!-- Submit Button -->
            <button
              id="submitBtn"
              type="submit"
              class="w-full bg-gradient-to-r from-blue-600 via-purple-600 to-pink-600 py-5 rounded-2xl text-xl font-bold hover:scale-[1.02] transition-all duration-300 shadow-2xl"
            >
              Submit Project 🚀
            </button>
          </form>

        <% } %>

        <!-- Submission Status -->
        <% if (submission) { %>
          <%
            let statusClasses = "bg-yellow-500/10 border-yellow-500/30 text-yellow-400";
            let statusIcon = "⏳";

            if (submission.status === "approved") {
              statusClasses = "bg-green-500/10 border-green-500/30 text-green-400";
              statusIcon = "✅";
            } else if (submission.status === "rejected") {
              statusClasses = "bg-red-500/10 border-red-500/30 text-red-400";
              statusIcon = "❌";
            }
          %>

          <div class="mt-10 border rounded-2xl p-6 <%= statusClasses %>">
            <h3 class="text-2xl font-bold mb-3">
              <%= statusIcon %> Submission Status
            </h3>

            <p class="text-lg">
              Current Status:
              <span class="font-extrabold uppercase">
                <%= submission.status %>
              </span>
            </p>

            <% if (submission.status === "rejected") { %>
              <p class="mt-4">
                Please improve your project and submit again.
              </p>
            <% } %>
          </div>
        <% } %>

      </div>
    </div>
  </div>
</section>

<%- include("partial/footer") %>

<script>
  const form = document.getElementById("submitForm");

  if (form) {
    form.addEventListener("submit", function (e) {
      const link = document.getElementById("linkInput").value.trim();
      const fileInput = document.getElementById("fileInput");
      const hasFile = fileInput.files.length > 0;

      const errorMsg = document.getElementById("errorMsg");
      const loadingMsg = document.getElementById("loadingMsg");
      const submitBtn = document.getElementById("submitBtn");

      if (!link && !hasFile) {
        e.preventDefault();
        errorMsg.classList.remove("hidden");
        return;
      }

      errorMsg.classList.add("hidden");
      loadingMsg.classList.remove("hidden");

      submitBtn.disabled = true;
      submitBtn.innerHTML = "⏳ Submitting...";
      submitBtn.classList.add("opacity-75", "cursor-not-allowed");
    });
  }
</script>