  <script src="https://cdn.tailwindcss.com"></script>

<!-- views/blog/index.ejs -->
<%- include("partial/nav") %>

<section class="min-h-screen bg-gradient-to-br from-slate-950 via-slate-900 to-black text-white py-20 px-6">
    <div class="max-w-7xl mx-auto">

        <!-- Header -->
        <div class="text-center mb-16">
            <span class="inline-block px-5 py-2 rounded-full bg-blue-500/10 border border-blue-500/30 text-blue-400 font-semibold mb-6">
                Student Success Stories
            </span>

            <h1 class="text-5xl md:text-7xl font-black mb-6 leading-tight">
                Explore Amazing
                <span class="bg-gradient-to-r from-blue-400 via-purple-400 to-pink-400 bg-clip-text text-transparent">
                    Projects
                </span>
            </h1>

            <p class="text-xl text-slate-400 max-w-3xl mx-auto">
                Discover real-world projects built by our talented students.
                Learn, get inspired, and showcase your own masterpiece.
            </p>
        </div>

        <!-- Blog Grid -->
        <% if (blogs.length > 0) { %>
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-10">

                <% blogs.forEach(blog => { %>
                    <article class="group bg-white/5 backdrop-blur-xl border border-white/10 rounded-3xl overflow-hidden hover:border-blue-500/40 hover:shadow-2xl hover:shadow-blue-500/10 transition-all duration-500">

                        <!-- Thumbnail -->
                        <div class="relative overflow-hidden">
                            <img
                                src="<%= blog.thumbnail %>"
                                alt="<%= blog.title %>"
                                class="w-full h-64 object-cover group-hover:scale-110 transition-transform duration-700"
                            >

                            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent"></div>

                            <span class="absolute top-5 left-5 px-4 py-2 rounded-full bg-blue-600 text-white text-xs font-bold shadow-lg">
                                <%= blog.course?.title || "Project" %>
                            </span>
                        </div>

                        <!-- Content -->
                        <div class="p-7">
                            <h2 class="text-2xl font-bold mb-4 group-hover:text-blue-400 transition">
                                <%= blog.title %>
                            </h2>

                            <p class="text-slate-400 leading-relaxed mb-6 line-clamp-3">
                                <%= blog.summary %>
                            </p>

                            <!-- Author -->
                            <div class="flex items-center justify-between mb-6">
                                <div class="flex items-center gap-3">
                                    <img
                                        src="<%= blog.author?.avatar || '/images/default-avatar.png' %>"
                                        class="w-12 h-12 rounded-full object-cover border-2 border-blue-500"
                                    >
                                    <div>
                                        <p class="font-semibold">
                                            <%= blog.author?.name || 'Student' %>
                                        </p>
                                        <p class="text-sm text-slate-500">
                                            <%= new Date(blog.createdAt).toLocaleDateString() %>
                                        </p>
                                    </div>
                                </div>
                            </div>

                            <!-- Buttons -->
                            <div class="flex gap-3">
                                <a
                                    href="/blogs/<%= blog._id %>"
                                    class="flex-1 text-center bg-gradient-to-r from-blue-600 to-purple-600 py-3 rounded-xl font-bold hover:scale-105 transition"
                                >
                                    View Project
                                </a>

                                <% if (blog.githubUrl) { %>
                                    <a
                                        href="<%= blog.githubUrl %>"
                                        target="_blank"
                                        class="px-5 py-3 rounded-xl bg-slate-800 hover:bg-slate-700 transition"
                                    >
                                        GitHub
                                    </a>
                                <% } %>
                            </div>
                        </div>
                    </article>
                <% }) %>

            </div>
        <% } else { %>

            <!-- Empty State -->
            <div class="text-center py-32">
                <div class="text-8xl mb-6">🚀</div>

                <h2 class="text-4xl font-bold mb-4">
                    No Projects Yet
                </h2>

                <p class="text-slate-400 text-lg mb-10">
                    Be the first student to publish your amazing project.
                </p>

                <a
                    href="/blogs/create"
                    class="inline-flex items-center gap-3 bg-gradient-to-r from-blue-600 to-purple-600 px-8 py-4 rounded-2xl font-bold hover:scale-105 transition"
                >
                    Publish Your Project
                </a>
            </div>

        <% } %>

    </div>
</section>

<%- include("partial/footer") %>