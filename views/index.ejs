<script src="https://cdn.tailwindcss.com"></script>

<div class="min-h-screen bg-gradient-to-br from-slate-50 via-white to-indigo-50">

    <div class="flex flex-col lg:flex-row">

        <!-- ================= SIDEBAR ================= -->
        <aside class="w-full lg:w-80 bg-white/90 backdrop-blur-xl border-r border-slate-200 shadow-2xl lg:min-h-screen">

            <div class="sticky top-0 p-8">

                <div class="mb-10">
                    <h2 class="text-3xl font-black bg-gradient-to-r from-indigo-600 to-purple-600 bg-clip-text text-transparent">
                        📚 Categories
                    </h2>
                    <p class="text-slate-500 mt-2">
                        Explore by your favorite domain
                    </p>
                </div>

                <% const categories = [
                    "All",
                    "Web Development",
                    "Data Science",
                    "App Development",
                    "AI/ML"
                ]; %>

                <nav class="space-y-3">

                    <% categories.forEach(cat => { %>
                        <a
                            href="/course?category=<%= encodeURIComponent(cat) %>&search=<%= encodeURIComponent(searchQuery || '') %>"
                            class="group flex items-center justify-between px-5 py-4 rounded-2xl font-semibold transition-all duration-300
                            <%= selectedCategory === cat
                                ? 'bg-gradient-to-r from-indigo-600 to-purple-600 text-white shadow-xl scale-105'
                                : 'text-slate-700 hover:bg-slate-100 hover:translate-x-2'
                            %>"
                        >
                            <span><%= cat %></span>

                            <% if (selectedCategory === cat) { %>
                                <span>✓</span>
                            <% } else { %>
                                <span class="opacity-0 group-hover:opacity-100 transition">
                                    →
                                </span>
                            <% } %>
                        </a>
                    <% }) %>

                </nav>

            </div>
        </aside>

        <!-- ================= MAIN CONTENT ================= -->
        <main class="flex-1 p-6 lg:p-10">

            <!-- Header -->
            <div class="max-w-7xl mx-auto mb-12">

                <div class="flex flex-col xl:flex-row xl:items-center xl:justify-between gap-8">

                    <div>
                        <h1 class="text-5xl font-black text-slate-900 leading-tight">
                            Browse Premium Courses
                        </h1>

                        <p class="text-slate-600 mt-4 text-lg max-w-2xl">
                            Master in-demand skills with expertly crafted,
                            industry-ready courses.
                        </p>
                    </div>

                    <!-- Search Form -->
                    <form
                        method="GET"
                        action="/course"
                        class="w-full xl:w-[500px]"
                    >
                        <input
                            type="hidden"
                            name="category"
                            value="<%= selectedCategory || 'All' %>"
                        >

                        <div class="flex items-center bg-white rounded-2xl shadow-xl border border-slate-200 p-2">
                            <input
                                type="text"
                                name="search"
                                value="<%= searchQuery || '' %>"
                                placeholder="Search your dream course..."
                                class="flex-1 px-5 py-3 outline-none text-slate-700 bg-transparent"
                            >

                            <button
                                type="submit"
                                class="px-8 py-3 rounded-xl bg-gradient-to-r from-indigo-600 to-purple-600 text-white font-semibold hover:scale-105 transition-all duration-300 shadow-lg"
                            >
                                Search
                            </button>
                        </div>
                    </form>

                </div>
            </div>

            <!-- Filter Info -->
            <div class="max-w-7xl mx-auto mb-10">
                <div class="inline-flex flex-wrap items-center gap-3 bg-white rounded-2xl px-6 py-4 shadow-md border border-slate-200">
                    <span class="text-slate-500">Showing results for:</span>

                    <span class="px-4 py-2 rounded-full bg-indigo-100 text-indigo-700 font-semibold">
                        <%= searchQuery?.trim() || "All Courses" %>
                    </span>

                    <span class="text-slate-400">in</span>

                    <span class="px-4 py-2 rounded-full bg-purple-100 text-purple-700 font-semibold">
                        <%= selectedCategory || "All" %>
                    </span>
                </div>
            </div>

            <!-- Courses Grid -->
            <div class="max-w-7xl mx-auto">

                <% if (courses && courses.length > 0) { %>

                    <div class="grid md:grid-cols-2 xl:grid-cols-3 gap-8">

                        <% courses.forEach(course => { %>

                            <div class="group bg-white rounded-3xl overflow-hidden shadow-lg hover:shadow-2xl border border-slate-100 transition-all duration-500 hover:-translate-y-3">

                                <!-- Thumbnail -->
                                <div class="relative overflow-hidden">

                                    <% if (course.thumbnail) { %>
                                        <img
                                            src="<%= course.thumbnail || '/default.jpg' %>"
                                            alt="<%= course.title %>"
                                            class="w-full h-56 object-cover group-hover:scale-110 transition-transform duration-700"
                                        >
                                    <% } else { %>
                                        <div class="w-full h-56 bg-gradient-to-br from-indigo-600 via-purple-600 to-pink-500 flex items-center justify-center text-white text-6xl font-black">
                                            <%= course.title?.charAt(0)?.toUpperCase() || "C" %>
                                        </div>
                                    <% } %>

                                    <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent"></div>

                                    <div class="absolute bottom-4 left-4">
                                        <span class="bg-white/20 backdrop-blur-lg text-white px-4 py-2 rounded-full text-sm font-semibold">
                                            Premium Course
                                        </span>
                                    </div>
                                </div>

                                <!-- Content -->
                                <div class="p-7">

                                    <h3 class="text-2xl font-bold text-slate-900 group-hover:text-indigo-600 transition mb-3 line-clamp-2">
                                        <%= course.title %>
                                    </h3>

                                    <p class="text-slate-600 leading-relaxed mb-6 line-clamp-3">
                                        <%= course.description || "Learn cutting-edge technologies with practical projects and real-world examples." %>
                                    </p>

                                    <!-- Rating -->
                                    <div class="flex items-center justify-between mb-6">

                                        <div class="flex items-center gap-2">
                                            <span class="text-yellow-400 text-lg">★★★★★</span>
                                            <span class="font-semibold text-slate-700">
                                                4.8
                                            </span>
                                        </div>

                                        <span class="text-slate-500 text-sm">
                                            1.5k+ Students
                                        </span>
                                    </div>

                                    <!-- Footer -->
                                    <div class="flex items-center justify-between">

                                        <div>
                                            <p class="text-sm text-slate-500">
                                                Course Price
                                            </p>

                                            <h4 class="text-3xl font-black text-slate-900">
                                                ₹<%= course.price || 0 %>
                                            </h4>
                                        </div>

                                        <a
                                            href="/course/<%= course._id %>"
                                            class="px-6 py-3 rounded-2xl bg-gradient-to-r from-indigo-600 to-purple-600 text-white font-semibold shadow-lg hover:scale-105 transition-all duration-300"
                                        >
                                            View Course →
                                        </a>

                                    </div>

                                </div>
                            </div>

                        <% }) %>

                    </div>

                <% } else { %>

                    <!-- Empty State -->
                    <div class="bg-white rounded-3xl shadow-xl border border-slate-200 p-16 text-center">

                        <div class="text-8xl mb-6">📚</div>

                        <h2 class="text-4xl font-black text-slate-900 mb-4">
                            No Courses Found
                        </h2>

                        <p class="text-slate-600 text-lg mb-8">
                            Try another search term or category.
                        </p>

                        <a
                            href="/course"
                            class="inline-block px-8 py-4 rounded-2xl bg-gradient-to-r from-indigo-600 to-purple-600 text-white font-semibold shadow-lg hover:scale-105 transition"
                        >
                            Browse All Courses
                        </a>

                    </div>

                <% } %>

            </div>

        </main>

    </div>

</div>