<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create New Task</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gradient-to-br from-slate-50 via-purple-50 to-indigo-100 min-h-screen">

<div class="flex min-h-screen">

    <!-- Sidebar -->
    <aside class="w-72 bg-white/90 backdrop-blur-xl shadow-2xl border-r border-gray-200 hidden lg:block">
        <div class="p-8">
            <h2 class="text-3xl font-extrabold bg-gradient-to-r from-purple-600 to-indigo-600 bg-clip-text text-transparent">
                Admin Panel
            </h2>
            <p class="text-gray-500 mt-2">Task Management</p>
        </div>

        <nav class="px-6 space-y-3">
            <a href="/admin/dashboard"
               class="flex items-center gap-3 px-5 py-4 rounded-2xl text-gray-700 hover:bg-gray-100 transition-all duration-300">
                <span class="text-xl">📊</span>
                <span class="font-medium">Dashboard</span>
            </a>

            <a href="/admin/add-task"
               class="flex items-center gap-3 px-5 py-4 rounded-2xl bg-gradient-to-r from-purple-600 to-indigo-600 text-white shadow-lg">
                <span class="text-xl">📝</span>
                <span class="font-semibold">Add Task</span>
            </a>

            <a href="/admin/tasks"
               class="flex items-center gap-3 px-5 py-4 rounded-2xl text-gray-700 hover:bg-gray-100 transition-all duration-300">
                <span class="text-xl">📋</span>
                <span class="font-medium">Manage Tasks</span>
            </a>
        </nav>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 p-6 lg:p-10">

        <!-- Header -->
        <div class="mb-10">
            <h1 class="text-5xl font-black text-gray-800 mb-3">
                Create New Task
            </h1>
            <p class="text-lg text-gray-600">
                Assign professional tasks to your enrolled students.
            </p>
        </div>

        <!-- Form Card -->
        <div class="max-w-3xl">
            <div class="bg-white/95 backdrop-blur-xl rounded-3xl shadow-2xl border border-white p-8 lg:p-10">

                <form action="/admin/add-task" method="POST" class="space-y-8">

                    <!-- Task Title -->
                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-3">
                            Task Title
                        </label>
                        <input
                            type="text"
                            name="title"
                            required
                            placeholder="Enter task title..."
                            class="w-full px-5 py-4 rounded-2xl border border-gray-300 focus:ring-4 focus:ring-purple-200 focus:border-purple-500 outline-none transition-all"
                        >
                    </div>

                    <!-- Description -->
                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-3">
                            Description
                        </label>
                        <textarea
                            name="description"
                            rows="5"
                            placeholder="Describe the task in detail..."
                            class="w-full px-5 py-4 rounded-2xl border border-gray-300 focus:ring-4 focus:ring-purple-200 focus:border-purple-500 outline-none transition-all resize-none"
                        ></textarea>
                    </div>

                    <!-- Course Selection -->
                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-3">
                            Assign to Course
                        </label>

                        <select
                            name="course"
                            required
                            class="w-full px-5 py-4 rounded-2xl border border-gray-300 focus:ring-4 focus:ring-purple-200 focus:border-purple-500 outline-none transition-all"
                        >
                            <option value="">Select a Course</option>

                            <% if (courses && courses.length > 0) { %>
                                <% courses.forEach(course => { %>
                                    <option
                                        value="<%= course._id %>"
                                        <%= selectedCourse &&
                                            course._id &&
                                            selectedCourse.toString() === course._id.toString()
                                                ? 'selected'
                                                : '' %>>
                                        <%= course.title %>
                                    </option>
                                <% }) %>
                            <% } %>
                        </select>
                    </div>
                    <!-- =============================
ADD THIS FIELD ABOVE DUE DATE
============================= -->
<div>
    <label class="block text-sm font-bold text-gray-700 mb-3">
        Student Email (Optional)
    </label>

    <input
        type="email"
        name="studentEmail"
        placeholder="student@example.com"
        class="w-full px-5 py-4 rounded-2xl border border-gray-300 focus:ring-4 focus:ring-purple-200 focus:border-purple-500 outline-none transition-all"
    >
</div>
                    <!-- Due Date -->
                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-3">
                            Due Date
                        </label>
                        <input
                            type="date"
                            name="dueDate"
                            class="w-full px-5 py-4 rounded-2xl border border-gray-300 focus:ring-4 focus:ring-purple-200 focus:border-purple-500 outline-none transition-all"
                        >
                    </div>

                    <!-- Submit Button -->
                    <button
                        type="submit"
                        class="group relative w-full bg-gradient-to-r from-purple-600 to-indigo-600 text-white py-5 rounded-2xl font-bold text-lg shadow-xl hover:shadow-2xl hover:scale-[1.02] transition-all duration-300"
                    >
                        <span class="flex items-center justify-center gap-3">
                            🚀 Create Task
                        </span>
                    </button>

                </form>
            </div>
        </div>

    </main>
</div>

</body>
</html>