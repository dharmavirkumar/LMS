<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Submissions</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gradient-to-br from-slate-950 via-slate-900 to-black text-white min-h-screen">

    <div class="max-w-7xl mx-auto px-6 py-10">

        <!-- Header -->
        <div class="mb-12">
            <h1 class="text-5xl font-extrabold bg-gradient-to-r from-purple-400 via-pink-500 to-cyan-400 bg-clip-text text-transparent">
                All Project Submissions
            </h1>
            <p class="text-gray-400 mt-3 text-lg">
                Review student projects, GitHub repositories, live demos, and uploaded proof files.
            </p>
        </div>

        <% if (!submissions || submissions.length === 0) { %>
            <div class="bg-slate-800/50 border border-slate-700 rounded-3xl p-16 text-center">
                <div class="text-8xl mb-6">📭</div>
                <h2 class="text-3xl font-bold mb-4">No Submissions Found</h2>
                <p class="text-gray-400">
                    Student submissions will appear here automatically.
                </p>
            </div>
        <% } else { %>

        <div class="grid grid-cols-1 xl:grid-cols-2 gap-8">

            <% submissions.forEach(submission => { %>
            <div class="bg-slate-900/80 backdrop-blur-xl border border-slate-700 rounded-3xl overflow-hidden shadow-2xl hover:border-purple-500 transition duration-300">

                <!-- Status Bar -->
                <div class="px-6 py-4 border-b border-slate-700 flex justify-between items-center">
                    <div>
                        <h2 class="text-2xl font-bold text-white">
                            <%= submission.task?.title || "Deleted Task" %>
                        </h2>
                        <p class="text-sm text-gray-400 mt-1">
                            Submitted by <span class="text-purple-400 font-semibold">
                                <%= submission.user?.name || "Deleted User" %>
                            </span>
                        </p>
                    </div>

                    <span class="px-4 py-2 rounded-full text-sm font-bold
                        <% if(submission.status === 'approved'){ %>
                            bg-green-500/20 text-green-400
                        <% } else if(submission.status === 'rejected'){ %>
                            bg-red-500/20 text-red-400
                        <% } else { %>
                            bg-yellow-500/20 text-yellow-400
                        <% } %>
                    ">
                        <%= submission.status.toUpperCase() %>
                    </span>
                </div>

                <div class="p-6 space-y-6">

                    <!-- Student Details -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div class="bg-slate-800 rounded-2xl p-4">
                            <p class="text-gray-400 text-sm">Student Name</p>
                            <p class="font-bold text-lg">
                                <%= submission.user?.name || "Deleted User" %>
                            </p>
                        </div>

                        <div class="bg-slate-800 rounded-2xl p-4">
                            <p class="text-gray-400 text-sm">Submission Date</p>
                            <p class="font-bold text-lg">
                                <%= new Date(submission.createdAt).toLocaleString() %>
                            </p>
                        </div>
                    </div>

                    <!-- Project Links -->
                    <div class="space-y-4">

                        <% if(submission.link){ %>
                        <a href="<%= submission.link %>"
                           target="_blank"
                           class="flex items-center justify-between bg-gradient-to-r from-blue-600 to-cyan-600 px-5 py-4 rounded-2xl hover:scale-[1.02] transition">
                            <span class="font-semibold">🌐 Open Project / Live Demo</span>
                            <span>↗</span>
                        </a>
                        <% } %>

                        <% if(submission.github){ %>
                        <a href="<%= submission.github %>"
                           target="_blank"
                           class="flex items-center justify-between bg-gradient-to-r from-gray-700 to-gray-900 px-5 py-4 rounded-2xl hover:scale-[1.02] transition">
                            <span class="font-semibold">💻 View GitHub Repository</span>
                            <span>↗</span>
                        </a>
                        <% } %>

                        <% if(submission.file){ %>
                        <a href="<%= submission.file %>"
                           target="_blank"
                           class="flex items-center justify-between bg-gradient-to-r from-purple-600 to-pink-600 px-5 py-4 rounded-2xl hover:scale-[1.02] transition">
                            <span class="font-semibold">📎 View Uploaded Proof</span>
                            <span>↗</span>
                        </a>
                        <% } %>

                    </div>

                    <!-- Submission Preview -->
                    <% if(submission.file){ %>
                    <div class="rounded-2xl overflow-hidden border border-slate-700">
                        <img
                            src="<%= submission.file %>"
                            alt="Project Screenshot"
                            class="w-full h-72 object-cover hover:scale-105 transition duration-500"
                        >
                    </div>
                    <% } %>

                    <!-- Admin Actions -->
                    <div class="grid grid-cols-2 gap-4 pt-4">

                        <form action="/admin/approve-submission/<%= submission._id %>" method="POST">
                            <button class="w-full py-4 rounded-2xl bg-gradient-to-r from-green-500 to-emerald-600 font-bold hover:shadow-lg hover:shadow-green-500/30 transition">
                                ✅ Approve
                            </button>
                        </form>

                        <form action="/admin/reject-submission/<%= submission._id %>" method="POST">
                            <button class="w-full py-4 rounded-2xl bg-gradient-to-r from-red-500 to-rose-600 font-bold hover:shadow-lg hover:shadow-red-500/30 transition">
                                ❌ Reject
                            </button>
                        </form>

                    </div>

                </div>
            </div>
            <% }) %>

        </div>

        <% } %>

    </div>

</body>
</html>