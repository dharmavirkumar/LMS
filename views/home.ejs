<style>
/* Orbit Rotation */
.orbit {
  position: relative;
  animation: rotateOrbit 20s linear infinite;
}

@keyframes rotateOrbit {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* Each Icon Position */
.orbit-item {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: rotate(calc(45deg * var(--i))) translate(130px) rotate(calc(-45deg * var(--i)));
}

/* Icon Style */
.orbit-item img {
  width: 40px;
  height: 40px;
  background: white;
  padding: 6px;
  border-radius: 10px;
  box-shadow: 0 10px 20px rgba(0,0,0,0.2);
}

/* Optional Hover Effect */
.orbit-item img:hover {
  transform: scale(1.2);
  transition: 0.3s;
}
</style>
