<!-- ================= TOP PROJECTS ================= -->
<section class="py-20 bg-gray-100">

  <h2 class="text-4xl font-bold text-center mb-14">
    Top Projects
  </h2>

  <div class="max-w-7xl mx-auto grid md:grid-cols-3 gap-8 px-6">

    <% courses.forEach(course => { %>

      <div class="bg-white rounded-2xl shadow hover:shadow-xl transition overflow-hidden">

        <!-- Thumbnail -->
        <img src="<%= course.thumbnail || '/default.jpg' %>" 
             class="w-full h-56 object-cover">

        <!-- Content -->
        <div class="p-6 text-center">

          <h3 class="text-xl font-bold mb-4">
            <%= course.title %>
          </h3>

          <a href="/course/<%= course._id %>"
             class="inline-block bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-full">

            View Project →

          </a>

        </div>

      </div>

    <% }) %>

  </div>

</section>

</section>




<!-- ================= WHY CHOOSE ================= -->
<section class="bg-gradient-to-br from-black via-blue-950 to-black text-white py-24 px-6">

  <div class="max-w-6xl mx-auto text-center">

    <!-- Heading -->
    <h1 class="text-4xl md:text-5xl font-bold mb-6">
      Why Choose 
      <span class="bg-gradient-to-r from-cyan-400 to-blue-500 text-transparent bg-clip-text">
        Gyansify ?
      </span>
    </h1>

    <p class="text-gray-400 max-w-2xl mx-auto mb-16">
      Experience the difference with live doubt clearing sessions, enhanced interactive 
      training, and personalized mentorship that sets us apart from the competition.
    </p>

    <!-- Comparison Box -->
    <div class="bg-white/5 border border-white/10 rounded-2xl p-8 backdrop-blur-lg">

      <!-- Header -->
      <div class="grid grid-cols-3 items-center mb-6">

        <div class="text-left text-gray-400">Features</div>

        <div class="flex flex-col items-center">
          <div class="bg-gradient-to-r from-blue-500 to-purple-600 px-4 py-2 rounded-xl mb-2">
            <span class="font-bold">G</span>
          </div>
          <p class="font-semibold">Gyansify</p>
          <div class="w-16 h-1 bg-gradient-to-r from-blue-500 to-purple-600 rounded-full mt-1"></div>
        </div>

        <div class="flex flex-col items-center">
          <div class="bg-gray-700 px-4 py-2 rounded-xl mb-2 text-sm">
            Others
          </div>
          <p class="text-gray-400">Other Platforms</p>
        </div>

      </div>

      <!-- Dynamic Features -->
      <% const comparisonFeatures = [
        { name: "1-on-1 Doubt Clearing", gyansify: true, others: false },
        { name: "Interactive Lectures", gyansify: true, others: false },
        { name: "Mentorship", gyansify: true, others: false },
        { name: "Project Learning", gyansify: true, others: true },
        { name: "Live Project-Based Learning", gyansify: true, others: false },
        { name: "Paid Internships with Stipend", gyansify: true, others: false },
        { name: "Multiple Industry Certifications", gyansify: true, others: false },
        { name: "Job Placement Assistance", gyansify: true, others: true },
        { name: "Industry Expert Mentors", gyansify: true, others: false },
        { name: "Flexible Scheduling", gyansify: true, others: false }
      ]; %>

      <% comparisonFeatures.forEach(f => { %>
        <div class="grid grid-cols-3 items-center py-4 border-t border-white/10">

          <!-- Feature -->
          <div class="text-left text-gray-300">
            <%= f.name %>
          </div>

          <!-- NullClass -->
          <div class="text-center text-green-400 text-lg">
            <%= f.gyansify ? "✅" : "❌" %>
          </div>

          <!-- Others -->
          <div class="text-center text-red-400 text-lg">
            <%= f.others ? "✅" : "❌" %>
          </div>

        </div>
      <% }) %>

    </div>

  </div>
</section>


<!-- ================= refund ================= -->

<section class="bg-gradient-to-br from-black via-blue-950 to-black text-white py-24 px-6 my-10">
  <div class="max-w-7xl mx-auto">
    
    <!-- Header -->
    <div class="text-center mb-20">
      <span class="inline-block px-6 py-3 rounded-full bg-purple-500/20 text-purple-300 border border-purple-500/30 text-sm font-semibold mb-6">
        Refund Policy
      </span>
      
      <h1 class="text-5xl md:text-7xl font-bold text-white mb-6">
        Performance-Based Refund Policy
      </h1>
      
      <p class="text-xl text-slate-300 max-w-4xl mx-auto leading-relaxed">
        Learners may become eligible for a course fee refund upon successful completion of all required criteria and evaluation standards.
      </p>
    </div>

    <!-- Main Content -->
    <div class="grid lg:grid-cols-3 gap-8">
      
      <!-- Left Content -->
      <div class="lg:col-span-2 space-y-8">
        
        <!-- Eligibility -->
        <div class="bg-white/5 backdrop-blur-lg border border-white/10 rounded-3xl p-10">
          <h2 class="text-4xl font-bold text-white mb-8">
            Refund Eligibility Requirements
          </h2>
          
          <div class="space-y-6">
            <div class="flex gap-5">
              <div class="w-12 h-12 rounded-full bg-green-500/20 flex items-center justify-center flex-shrink-0">
                <span class="text-green-400 text-2xl">✓</span>
              </div>
              <div>
                <h3 class="text-2xl font-semibold text-white mb-2">
                  Complete All Modules
                </h3>
                <p class="text-slate-300 text-lg">
                  All lessons, assignments, and assessments must be completed within the program timeline.
                </p>
              </div>
            </div>

            <div class="flex gap-5">
              <div class="w-12 h-12 rounded-full bg-green-500/20 flex items-center justify-center flex-shrink-0">
                <span class="text-green-400 text-2xl">✓</span>
              </div>
              <div>
                <h3 class="text-2xl font-semibold text-white mb-2">
                  Submit Required Projects
                </h3>
                <p class="text-slate-300 text-lg">
                  All mandatory projects must be submitted before the deadline for evaluation.
                </p>
              </div>
            </div>

            <div class="flex gap-5">
              <div class="w-12 h-12 rounded-full bg-green-500/20 flex items-center justify-center flex-shrink-0">
                <span class="text-green-400 text-2xl">✓</span>
              </div>
              <div>
                <h3 class="text-2xl font-semibold text-white mb-2">
                  Quality & Evaluation Approval
                </h3>
                <p class="text-slate-300 text-lg">
                  Projects must meet defined quality standards and pass internal evaluation conducted by the review team.
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- AI Policy -->
        <div class="bg-red-500/10 border border-red-500/30 rounded-3xl p-10">
          <div class="flex items-center gap-4 mb-6">
            <div class="w-16 h-16 rounded-full bg-red-500/20 flex items-center justify-center">
              <span class="text-4xl">⚠️</span>
            </div>
            <h2 class="text-4xl font-bold text-red-400">
              Academic Integrity Policy
            </h2>
          </div>

          <p class="text-xl text-slate-200 leading-relaxed mb-6">
            All submissions must represent the learner’s own understanding and effort. Use of automated tools or copied content that bypasses learning objectives may lead to disqualification from refund eligibility.
          </p>

          <ul class="space-y-4 text-lg text-slate-300">
            <li class="flex items-start gap-3">
              <span class="text-red-400 mt-1">✖</span>
              Submissions must reflect genuine learning and effort.
            </li>
            <li class="flex items-start gap-3">
              <span class="text-red-400 mt-1">✖</span>
              Plagiarism or misuse of tools may result in rejection.
            </li>
            <li class="flex items-start gap-3">
              <span class="text-red-400 mt-1">✖</span>
              Final decision regarding eligibility rests with the review team.
            </li>
          </ul>
        </div>

        <!-- Terms -->
        <div class="bg-white/5 backdrop-blur-lg border border-white/10 rounded-3xl p-10">
          <h2 class="text-4xl font-bold text-white mb-8">
            Additional Terms
          </h2>

          <ul class="space-y-5 text-lg text-slate-300">
            <li class="flex gap-4">
              <span class="text-purple-400 font-bold">01.</span>
              Refund requests must be submitted within the specified timeline after project evaluation.
            </li>
            <li class="flex gap-4">
              <span class="text-purple-400 font-bold">02.</span>
              Processing timelines may vary based on payment method and verification.
            </li>
            <li class="flex gap-4">
              <span class="text-purple-400 font-bold">03.</span>
              Any misuse, fraud, or violation of guidelines may lead to disqualification.
            </li>
            <li class="flex gap-4">
              <span class="text-purple-400 font-bold">04.</span>
              The organization reserves the right to modify or update this policy at any time.
            </li>
          </ul>
        </div>
      </div>

      <!-- Sidebar -->
      <div class="space-y-8">
        
        <div class="bg-gradient-to-br from-emerald-500 to-green-600 rounded-3xl p-10 text-center shadow-2xl">
          <div class="text-7xl mb-6">💰</div>
          <h3 class="text-4xl font-bold text-white mb-4">
            Eligible for Refund
          </h3>
          <p class="text-xl text-white font-semibold">
            Based on performance & completion
          </p>
        </div>

        <div class="bg-white/5 backdrop-blur-lg border border-white/10 rounded-3xl p-8">
          <h4 class="text-3xl font-bold text-white mb-6">
            Quick Summary
          </h4>

          <div class="space-y-4 text-slate-300">
            <p>✓ Complete all modules</p>
            <p>✓ Submit required projects</p>
            <p>✓ Follow academic guidelines</p>
            <p>✓ Pass evaluation</p>
            <p>✓ Become eligible for refund</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

