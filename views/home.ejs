          "Learners trained in hands-on projects",
          "Companies recognize our internship validation",
          "Years of project-driven training experience",
          "Continued mentor & community support"
        ]; %>

        <div class="grid sm:grid-cols-2 gap-4">
          <% careerFeatures.forEach(f => { %>
            <div class="bg-white shadow-sm border rounded-xl p-4 text-gray-700">
