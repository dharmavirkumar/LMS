<style>
.logo-item {
  min-width: 140px;
  text-align: center;
  /* opacity: 0.7;
  transition: all 0.3s ease; */
}
.logo-item img {
  height: 40px;
  margin: 0 auto 8px;
}
.logo-item p {
  font-size: 14px;
  color: #555;
}
.logo-item:hover {
  opacity: 1;
  transform: scale(1.05);
}

/* smooth marquee */
@keyframes marquee {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

@keyframes marqueeReverse {
  0% { transform: translateX(-50%); }
  100% { transform: translateX(0); }
}

.marquee {
  width: max-content;
  animation: marquee 25s linear infinite;
}

.marquee-reverse {
  width: max-content;
  animation: marqueeReverse 25s linear infinite;
}

/* pause on hover */
/* .marquee:hover,
.marquee-reverse:hover {
  animation-play-state: paused;
} */

/* fade edges (premium look) */
section::before,
section::after {
  content: "";
  position: absolute;
  top: 0;
  width: 120px;
  height: 100%;
  z-index: 2;
}

