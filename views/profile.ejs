<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/tailwindcss/2.2.19/tailwind.min.css"/>
<%- include("partial/nav") %>

<section class="relative min-h-screen overflow-hidden bg-slate-950 py-20 px-4 sm:px-6 lg:px-8">

  <!-- Animated Background -->
  <div class="absolute inset-0">
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-indigo-600/20 rounded-full blur-3xl animate-pulse"></div>
    <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-pink-600/20 rounded-full blur-3xl animate-pulse"></div>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_rgba(99,102,241,0.15),_transparent_35%),radial-gradient(circle_at_bottom_left,_rgba(236,72,153,0.12),_transparent_35%)]"></div>
  </div>

  <div class="relative max-w-6xl mx-auto">

    <% if (user) { %>
      <div class="bg-white/10 backdrop-blur-3xl border border-white/20 rounded-[2rem] shadow-2xl overflow-hidden">

        <!-- Cover Banner -->
        <div class="relative h-72 bg-gradient-to-r from-indigo-700 via-purple-700 to-pink-700">
          <div class="absolute inset-0 bg-black/20"></div>

          <!-- Decorative Shapes -->
          <div class="absolute top-10 left-10 w-24 h-24 border border-white/20 rounded-full"></div>
          <div class="absolute bottom-10 right-16 w-32 h-32 border border-white/10 rounded-full"></div>
        </div>

        <!-- Profile Section -->
        <div class="relative px-8 lg:px-14 pb-14">

          <!-- Avatar -->
          <div class="-mt-28 flex justify-center lg:justify-start">
            <div class="relative group">
              <img
                src="<%= user.avatar || 'https://ui-avatars.com/api/?name=' + encodeURIComponent(user.name || 'User') + '&background=4f46e5&color=fff&size=256' %>"
                alt="<%= user.name || 'User' %>"
                class="w-52 h-52 rounded-full border-8 border-white object-cover shadow-[0_20px_60px_rgba(0,0,0,0.45)] group-hover:scale-105 transition duration-500"
              >
              <div class="absolute bottom-4 right-4 w-8 h-8 bg-green-500 border-4 border-white rounded-full"></div>
            </div>
          </div>

          <!-- User Info -->
          <div class="mt-8 lg:-mt-40 lg:ml-64 text-center lg:text-left">
            <h1 class="text-5xl font-black text-white tracking-tight">
              <%= user.name || 'Unknown User' %>
            </h1>

            <p class="mt-3 text-xl text-indigo-200">
              <%= user.email || 'No email available' %>
            </p>

            <div class="flex flex-wrap justify-center lg:justify-start gap-3 mt-6">
              <span class="px-4 py-2 bg-indigo-500/20 text-indigo-200 rounded-full text-sm font-semibold border border-indigo-400/20">
                🎓 Student
              </span>
              <span class="px-4 py-2 bg-purple-500/20 text-purple-200 rounded-full text-sm font-semibold border border-purple-400/20">
                🚀 Learner
              </span>
              <span class="px-4 py-2 bg-pink-500/20 text-pink-200 rounded-full text-sm font-semibold border border-pink-400/20">
                ⭐ Premium Member
              </span>
            </div>
          </div>

          <!-- Bio Card -->
          <div class="mt-14">
            <div class="bg-white/5 border border-white/10 rounded-3xl p-8 hover:bg-white/10 transition duration-300">
              <h2 class="text-2xl font-bold text-white mb-5 flex items-center gap-3">
                📝 About Me
              </h2>

              <p class="text-gray-300 text-lg leading-relaxed">
                <%= user.bio || "No bio added yet. Share your journey, goals, and aspirations with the community." %>
              </p>
            </div>
          </div>

          <!-- Statistics -->
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-14">

            <div class="group bg-gradient-to-br from-indigo-500/10 to-indigo-700/10 border border-indigo-500/20 rounded-3xl p-8 text-center hover:scale-105 transition duration-500">
              <div class="text-6xl mb-4 group-hover:rotate-6 transition">🎓</div>
              <h3 class="text-2xl font-bold text-white">Student</h3>
              <p class="text-indigo-200 mt-2">Learning Every Day</p>
            </div>

            <div class="group bg-gradient-to-br from-purple-500/10 to-purple-700/10 border border-purple-500/20 rounded-3xl p-8 text-center hover:scale-105 transition duration-500">
              <div class="text-6xl mb-4 group-hover:rotate-6 transition">🚀</div>
              <h3 class="text-2xl font-bold text-white">Growth</h3>
              <p class="text-purple-200 mt-2">Building Future Skills</p>
            </div>

            <div class="group bg-gradient-to-br from-pink-500/10 to-pink-700/10 border border-pink-500/20 rounded-3xl p-8 text-center hover:scale-105 transition duration-500">
              <div class="text-6xl mb-4 group-hover:rotate-6 transition">🏆</div>
              <h3 class="text-2xl font-bold text-white">Achievements</h3>
              <p class="text-pink-200 mt-2">Success Ahead</p>
            </div>

          </div>

          <!-- Action Buttons -->
          <div class="flex flex-col sm:flex-row justify-center lg:justify-start gap-5 mt-14">

            <a
              href="/profile/edit"
              class="group inline-flex items-center justify-center gap-3 px-10 py-5 bg-gradient-to-r from-indigo-600 via-purple-600 to-pink-600 text-white font-bold rounded-2xl shadow-2xl hover:shadow-pink-500/25 hover:scale-105 transition duration-300"
            >
              ✏️ Edit Profile
              <span class="group-hover:translate-x-1 transition">→</span>
            </a>

            <a
              href="/auth/dashboard"
              class="inline-flex items-center justify-center gap-3 px-10 py-5 bg-white/10 border border-white/20 text-white font-bold rounded-2xl hover:bg-white/20 hover:scale-105 transition duration-300"
            >
              🏠 Dashboard
            </a>

          </div>

        </div>
      </div>

    <% } else { %>

      <!-- Error State -->
      <div class="max-w-2xl mx-auto bg-white/10 backdrop-blur-3xl border border-red-500/30 rounded-[2rem] p-16 text-center shadow-2xl">
        <div class="text-9xl mb-8 animate-bounce">😕</div>

        <h1 class="text-5xl font-black text-white mb-6">
          User Not Found
        </h1>

        <p class="text-red-300 text-xl mb-10 leading-relaxed">
          We couldn't locate your profile. Please login again to continue.
        </p>

        <a
          href="/login"
          class="inline-flex items-center gap-4 px-10 py-5 bg-gradient-to-r from-indigo-600 to-purple-600 text-white font-bold rounded-2xl shadow-2xl hover:scale-105 transition duration-300"
        >
          🔐 Go to Login
        </a>
      </div>

    <% } %>

  </div>
</section>

<%- include("partial/footer") %>