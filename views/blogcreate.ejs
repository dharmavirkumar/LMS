  <script src="https://cdn.tailwindcss.com"></script>

<!-- views/blog/create.ejs -->
<%- include("partial/nav") %>

<section class="max-w-4xl mx-auto py-12 px-4">
  <div class="bg-white rounded-3xl shadow-xl p-8">
    <h1 class="text-4xl font-bold mb-8">
      Publish Your Project
    </h1>

    <form
      action="/blogs/create"
      method="POST"
      enctype="multipart/form-data"
      class="space-y-6"
    >
      <input
        type="text"
        name="title"
        required
        placeholder="Project Title"
        class="w-full p-4 border rounded-xl"
      >

      <textarea
        name="summary"
        rows="5"
        required
        placeholder="Short Summary"
        class="w-full p-4 border rounded-xl"
      ></textarea>

      <input
        type="file"
        name="thumbnail"
        required
        accept="image/*"
        class="w-full p-4 border rounded-xl"
      >

      <input
        type="url"
        name="githubUrl"
        required
        placeholder="GitHub Repository URL"
        class="w-full p-4 border rounded-xl"
      >

      <input
        type="url"
        name="liveUrl"
        placeholder="Live Demo URL"
        class="w-full p-4 border rounded-xl"
      >

      <select
        name="course"
        class="w-full p-4 border rounded-xl"
      >
        <% courses.forEach(course => { %>
          <option value="<%= course._id %>">
            <%= course.title %>
          </option>
        <% }) %>
      </select>

      <button
        type="submit"
        class="w-full bg-gradient-to-r from-blue-600 to-purple-600 text-white py-4 rounded-xl font-bold"
      >
        Publish Blog
      </button>
    </form>
  </div>
</section>

<%- include("partial/footer") %>