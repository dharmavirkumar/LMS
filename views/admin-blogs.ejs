<!-- views/admin-blogs.ejs -->
<%- include("partial/nav") %>

<section class="max-w-7xl mx-auto py-12 px-4">
    <h1 class="text-5xl font-bold mb-10">
        Blog Management
    </h1>

    <div class="grid gap-8">
        <% blogs.forEach(blog => { %>
            <div class="bg-white rounded-3xl shadow-xl overflow-hidden">
                <div class="md:flex">
                    <img
                        src="<%= blog.thumbnail %>"
                        class="w-full md:w-80 h-64 object-cover"
                    >

                    <div class="p-8 flex-1">
                        <div class="flex justify-between items-start mb-4">
                            <h2 class="text-3xl font-bold">
                                <%= blog.title %>
                            </h2>

                            <span class="px-4 py-2 rounded-full text-sm font-bold
                                <%= blog.status === 'approved'
                                    ? 'bg-green-100 text-green-700'
                                    : blog.status === 'rejected'
                                    ? 'bg-red-100 text-red-700'
                                    : 'bg-yellow-100 text-yellow-700' %>">
                                <%= blog.status.toUpperCase() %>
                            </span>
                        </div>

                        <p class="text-gray-600 mb-6">
                            <%= blog.summary %>
                        </p>

                        <div class="mb-6 space-y-2">
                            <p><strong>Student:</strong> <%= blog.author.name %></p>
                            <p><strong>Email:</strong> <%= blog.author.email %></p>
                            <p><strong>Course:</strong> <%= blog.course?.title || 'N/A' %></p>
                        </div>

                        <div class="flex gap-4">
                            <a
                                href="/blogs/<%= blog._id %>"
                                target="_blank"
                                class="px-6 py-3 bg-blue-600 text-white rounded-xl"
                            >
                                View
                            </a>

                            <% if (blog.status !== "approved") { %>
                                <form action="/blogs/admin/<%= blog._id %>/approve" method="POST">
                                     <button class="px-6 py-3 bg-green-600 text-white rounded-xl">
                                   Approve
                                     </button>
                                    </form>
                            <% } %>

                            <% if (blog.status !== "rejected") { %>
                                <form action="/blogs/admin/<%= blog._id %>/reject" method="POST">
                                    <button class="px-6 py-3 bg-red-600 text-white rounded-xl">
                                        Reject
                                    </button>
                                </form>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>
</section>

<%- include("partial/footer") %>